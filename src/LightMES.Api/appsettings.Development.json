{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=light_mes;Username=postgres;Password=123456"
  },
  "JwtSettings": {
    "Secret": "SUPERSECRETKEYFORLIGHTMESSYSTEM!",
    "Issuer": "LightMES",
    "Audience": "MES_Clients",
    "ExpiryMinutes": 720
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/mes-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate":"{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
