###
GET {{LightMes.Api_HostAddress}}{{group}}?SearchText=CNC&PageNumber=1&PageSize=10
Accept: {{contentType}}

###
@equipmentId = f1716689-8058-4738-983b-c94aa94cf42e
GET {{LightMes.Api_HostAddress}}{{group}}/{{equipmentId}}
Accept: {{contentType}}

###
PUT {{LightMes.Api_HostAddress}}{{group}}/{{equipmentId}}
Content-Type: {{contentType}}
{
  "id" : "{{equipmentId}}",
  "equipmentName": "CNC加工中心 #1 (已升级主轴)",
  "location": "A车间-01区-新位置",
  "description": "主轴转速已升级至 12000 RPM"
}
