@LightMES.Api_HostAddress = https://localhost:9000
@group = /api/equipments
@contentType = application/json
###
POST {{LightMES.Api_HostAddress}}{{group}}
Content-Type: {{contentType}}
{
  "equipmentCode": "EQ-CNC-001",
  "equipmentName": "CNC加工中心 #1",
  "location" :"A车间-01区",
  "description": "主要用于箱体类零件的高精度加工"
}

